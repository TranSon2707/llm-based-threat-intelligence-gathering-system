# =========================
# Python & Environments
# =========================
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
.Python

# =========================
# Database & Data
# =========================
# Ignore the active SQLite database and Write-Ahead Logging (WAL) files
db/threat_intel.db
db/*.sqlite3
db/*.db
db/*.db-journal
db/*.db-wal
db/*.db-shm

# =========================
# Secrets & API Keys
# =========================
# NEVER push API keys (like AlienVault OTX) to Git
.env
secrets.json

# =========================
# Outputs & Reports
# =========================
# Ignore text files INSIDE the reports folder, but track the folder itself
reports/*.txt
!reports/.gitkeep

# =========================
# IDEs & OS Files
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db

# =========================
# Logs
# =========================
*.log
logs/